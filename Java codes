}

7. Abstraction (Shape Class)
â€‹Abstract classes cannot be instantiated; they serve as a blueprint for other classes.
abstract class Shape {
    abstract void calculate_area();

    void display_info() {
        System.out.println("This is a geometric shape.");
    }
}

class Circle extends Shape {
    double radius;
    Circle(double r) { this.radius = r; }

    @Override
    void calculate_area() {
        System.out.println("Circle Area: " + (Math.PI * radius * radius));
    }
}

class RectangleShape extends Shape {
    double l, w;
    RectangleShape(double l, double w) { this.l = l; this.w = w; }

    @Override
    void calculate_area() {
        System.out.println("Rectangle Area: " + (l * w));
    }
}

