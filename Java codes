2. Library Management System
â€‹This uses an ArrayList to manage a collection of objects.
import java.util.ArrayList;

class Book {
    String title, author, isbn;

    public Book(String title, String author, String isbn) {
        this.title = title;
        this.author = author;
        this.isbn = isbn;
    }

    @Override
    public String toString() {
        return "Title: " + title + " | Author: " + author + " | ISBN: " + isbn;
    }
}

class Library {
    private ArrayList<Book> books = new ArrayList<>();

    public void addBook(Book book) {
        books.add(book);
    }

    public void removeBook(String isbn) {
        books.removeIf(book -> book.isbn.equals(isbn));
    }

    public void displayBooks() {
        if (books.isEmpty()) System.out.println("Library is empty.");
        for (Book b : books) System.out.println(b);
    }
}


3. CARRENTAL Class
â€‹This logic uses conditional statements to determine the Rent based on the CarType.
class CARRENTAL {
    int CarId;
    String CarType;
    float Rent;

    public void GetCar(int id, String type) {
        this.CarId = id;
        this.CarType = type;
        this.Rent = GetRent(); // Assign rent based on type
    }

    private float GetRent() {
        if (CarType.equalsIgnoreCase("Small Car")) return 1000;
        else if (CarType.equalsIgnoreCase("Van")) return 800;
        else if (CarType.equalsIgnoreCase("SUV")) return 2500;
        else return 0;
    }

    public void ShowCar() {
        System.out.println("ID: " + CarId + " | Type: " + CarType + " | Rent: " + Rent);
    }
}

4. Resort Class
â€‹This highlights the use of internal calculation methods to derive values (Amount) from existing data.
import java.util.Scanner;

class Resort {
    private int RNo;
    private String Name;
    private float Charges;
    private int Days;

    private float Compute() {
        float baseAmount = Days * Charges;
        if (baseAmount > 11000) {
            return (float) (1.02 * baseAmount);
        }
        return baseAmount;
    }

    public void GetInfo() {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter Room No: "); RNo = sc.nextInt();
        sc.nextLine(); // Consume newline
        System.out.print("Enter Name: "); Name = sc.nextLine();
        System.out.print("Enter Charges: "); Charges = sc.nextFloat();
        System.out.print("Enter Days: "); Days = sc.nextInt();
    }

    public void DispInfo() {
        float amount = Compute();
        System.out.println("\n--- Guest Details ---");
        System.out.println("Room No: " + RNo);
        System.out.println("Name: " + Name);
        System.out.println("Charges/Day: " + Charges);
        System.out.println("Stay Duration: " + Days + " days");
        System.out.println("Total Amount: " + amount);
    }
}

5. Employee Class
â€‹This class manages payroll data and uses a private calculation method to determine the net pay.
import java.util.Scanner;

class Employee {
    int empno;
    String ename;
    float basic, hra, da, netpay;

    // Task specifies "Calculate" returns float
    public float Calculate() {
        return basic + hra + da;
    }

    public void havedata() {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter Employee No: "); empno = sc.nextInt();
        sc.nextLine(); 
        System.out.print("Enter Name: "); ename = sc.nextLine();
        System.out.print("Enter Basic Pay: "); basic = sc.nextFloat();
        System.out.print("Enter HRA: "); hra = sc.nextFloat();
        System.out.print("Enter DA: "); da = sc.nextFloat();
        
        // Invoke calculate and store in netpay
        netpay = Calculate();
    }

    public void dispdata() {
        System.out.println("\n--- Employee Slip ---");
        System.out.println("ID: " + empno + " | Name: " + ename);
        System.out.println("Basic: " + basic + " | HRA: " + hra + " | DA: " + da);
        System.out.println("Net Pay: " + netpay);
    }
}

6. Rectangle Area (Constructor Parameters)
