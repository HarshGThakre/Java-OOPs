8. Interface (Filterable)
â€‹Interfaces define a contract that multiple unrelated classes can implement in their own way.
interface Filterable {
    void apply_filter(String filter_type);
    void reset_filter();
}

class ImageProcessor implements Filterable {
    @Override
    public void apply_filter(String filter_type) {
        System.out.println("Applying " + filter_type + " filter to the image (e.g., Grayscale).");
    }

    @Override
    public void reset_filter() {
        System.out.println("Reverting image to original pixels.");
    }
}

class DataAnalyzer implements Filterable {
    @Override
    public void apply_filter(String filter_type) {
        System.out.println("Filtering dataset to remove " + filter_type + " records.");
    }

    @Override
    public void reset_filter() {
        System.out.println("Restoring all rows to the data table.");
    }
}

9. Method Overloading (Calculator)
class Calculator {
    // Two integers
    public int add(int a, int b) { return a + b; }

    // Three integers
    public int add(int a, int b, int c) { return a + b + c; }

    // Two doubles
    public double add(double a, double b) { return a + b; }

    public static void main(String[] args) {
        Calculator calc = new Calculator();
        System.out.println("2 ints: " + calc.add(10, 20));       // Calls method 1
        System.out.println("3 ints: " + calc.add(10, 20, 30));   // Calls method 2
        System.out.println("2 doubles: " + calc.add(10.5, 5.5)); // Calls method 3
    }
}

